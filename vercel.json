{
  "version": 2,
  "name": "resoflex-industrial-empire",
  "framework": "nextjs",
  "regions": ["cdg1"],
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index"
    },
    {
      "source": "/legal/(.*)",
      "destination": "/pages/legal/$1"
    },
    {
      "source": "/vault/(.*)",
      "destination": "/api/security/ip_lock"
    }
  ],
  "redirects": [
    {
      "source": "/old-resoflex/(.*)",
      "destination": "https://resofit.fit/$1",
      "permanent": true
    },
    {
      "source": "/name-ng/(.*)",
      "destination": "https://resofit.fit/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ]
}
